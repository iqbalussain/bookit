{
  "name": "bookit",
  "productName": "Bookit",
  "version": "1.0.0",
  "description": "Bookit - Modern booking management desktop application built with Electron and React.",
  "author": "Iqbal Ussain",
  "private": true,
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vite build",
    "build:dev": "vite build --mode development",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "package": "electron-forge package --platform=win32",
    "make": "electron-forge make --platform=win32",
    "start:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\""
  },
